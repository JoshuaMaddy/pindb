# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
# Pokemon tag pipeline: keep CSV + generated JSON local; scripts in dev/ are tracked.
/dev/*
!/dev/export_pokemon_tags.py
!/dev/tag_format.py
*.sqlite

# Node
node_modules
main.css
src/pindb/static/vendor/
# Svelte island build output (vite build, emptyOutDir)
src/pindb/static/islands/

# Pi coding agent (project-local sessions from .pi/settings.json)
.pi/sessions/

# Claude Code local permissions (per-machine)
.claude/settings.local.json

# Dev
.env

# Logs
*.log

# E2E screenshot failure artifacts (baselines in __screenshots__ are tracked)
tests/e2e/artifacts/

# Temp dirs
scripts/images
scripts/lucide/.cache/
scripts/*.csv

# Backups
/backups
*.dump

# Blue/green deploy state — host-local source of truth for which color is live
.deploy-active-color
