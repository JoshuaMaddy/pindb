{
  "engines": {
    "node": ">=20.0.0 <23"
  },
  "scripts": {
    "css:watch": "tailwindcss -i src/pindb/static/input.css -o src/pindb/static/main.css --watch",
    "css:build": "tailwindcss -i src/pindb/static/input.css -o src/pindb/static/main.css --minify",
    "css:contrast": "node scripts/check-theme-contrast.mjs",
    "vendor:build": "node scripts/vendor.mjs && node scripts/lucide/build-lucide.mjs",
    "build": "npm run css:build && npm run vendor:build"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "alpinejs": "^3.15.11",
    "htmx.org": "^2.0.10",
    "lucide": "^1.8.0",
    "marked": "^18.0.2",
    "notyf": "^3.10.0",
    "overtype": "^2.3.5",
    "tailwindcss": "^4.2.4",
    "tom-select": "^2.6.0"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-rc.17"
  }
}
