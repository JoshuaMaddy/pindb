{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": ["vite/client", "node"]
  },
  "include": ["frontend/**/*.ts", "frontend/**/*.svelte", "vite.config.ts"]
}
